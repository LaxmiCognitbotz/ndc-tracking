# Database Credentials
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_NAME=
SSL_MODE=

# JWT Credentials
JWT_SECRET=
JWT_ALGORITHM=
JWT_EXPIRE_MINUTES=

# Excel upload directory
UPLOAD_DIR=

# SMTP Config
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
EMAIL_RECIPIENT=

# SharePoint credentials
SHAREPOINT_TENANT_ID=
SHAREPOINT_SITE_URL=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_TARGET_FOLDER=

# SharePoint Reports Sync Config
SHAREPOINT_REPORTS_SUBFOLDER=
SHAREPOINT_SYNC_BACKGROUND_POLL=
SHAREPOINT_SYNC_SCHEDULED_TIMES=

# SharePoint SSL Verification config (set to 'false' or path to corporate CA bundle if running on a corporate network/VM behind SSL-decrypting proxies)
SHAREPOINT_SSL_VERIFY=true

# Proxy Settings (used in corporate networks / VMs if proxy/SSL-decryption is enabled)
PROXY_ENABLED=false
PROXY_URL=
PROXY_INSECURE_SSL=false

# SSO Configuration
# SSO_ENABLED — when True: Azure AD login enforced; when False: direct site access (no auth, no login UI)
SSO_ENABLED=True
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
# The redirect URI must match what is registered in Azure AD (typically pointing to the callback route)
AZURE_AD_REDIRECT_URI=http://localhost:8010/api/auth/callback
# Comma-separated list of superadmin emails that bypass approval and automatically get super_admin role
SUPER_ADMIN_EMAIL=